/* ==============================================
   HOME - ECOBITS PREMIUM
   Paleta: #FFB703 (amarillo/dorado) + #0A0A0A (negro premium)
   ============================================== */

/* Hero Premium */
.hero {
  position: relative;
  min-height: 88vh;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #2A2A2A 0%, #3A3A3A 50%, #2A2A2A 100%);
  overflow: hidden;
  padding: 80px 24px 60px;
}

.hero-orb-1 {
  width: 350px;
  height: 500px;
  background: radial-gradient(circle, rgba(255,183,3,0.15), transparent);
  top: -150px;
  right: -150px;
}

.hero-orb-2 {
  width: 300px;
  height: 400px;
  background: radial-gradient(circle, rgba(255,183,3,0.1), transparent);
  bottom: -100px;
  left: -100px;
}

.hero-orb-3 {
  width: 250px;
  height: 350px;
  background: radial-gradient(circle, rgba(255,183,3,0.08), transparent);
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
}

.hero-badge {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  background: rgba(255,183,3,0.12);
  border: 1px solid rgba(255,183,3,0.3);
  color: #FFB703;
  border-radius: 100px;
  padding: 8px 20px;
  font-size: 0.85rem;
  font-weight: 600;
  margin-bottom: 28px;
  backdrop-filter: blur(4px);
}

.hero-badge-dot {
  width: 8px;
  height: 8px;
  background: #FFB703;
  border-radius: 50%;
  animation: pulse 1.5s infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 1; transform: scale(1); }
  50% { opacity: 0.4; transform: scale(0.8); }
}

.hero-titulo {
  font-size: clamp(1.8rem, 4vw, 2.8rem);
  font-weight: 700;
  line-height: 1.3;
  margin-bottom: 24px;
}

.hero-titulo-acento {
  background: linear-gradient(135deg, #FFB703 0%, #E0E0E0 50%, #FFFFFF 75%, #FFB703 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  display: inline-block;
}
@keyframes subtleGlow {
  0%, 100% {
    filter: drop-shadow(0 0 5px rgba(255,183,3,0.3));
  }
  50% {
    filter: drop-shadow(0 0 15px rgba(255,183,3,0.6));
  }
}

.hero-subtitulo {
  font-size: 1.1rem;
  color: #B0B0B0;
  max-width: 520px;
  margin: 0 auto 36px;
}

.hero-acciones {
  display: flex;
  justify-content: center;
  gap: 20px;
  flex-wrap: wrap;
  margin-bottom: 52px;
}

.hero-btn-primario {
  display: inline-block;
  padding: 14px 36px;
  background: linear-gradient(135deg, #FFB703, #FFD966);
  color: #0A0A0A;
  border-radius: 50px;
  font-weight: 700;
  text-decoration: none;
  transition: all 0.3s ease;
  box-shadow: 0 4px 15px rgba(255,183,3,0.3);
}

.hero-btn-primario:hover {
  transform: translateY(-3px);
  box-shadow: 0 8px 25px rgba(255,183,3,0.5);
}

.hero-btn-secundario {
  display: inline-block;
  padding: 13px 32px;
  background: transparent;
  color: #FFB703;
  border: 1.5px solid #FFB703;
  border-radius: 50px;
  font-weight: 600;
  text-decoration: none;
  transition: all 0.3s ease;
}

.hero-btn-secundario:hover {
  background: rgba(255,183,3,0.1);
  transform: translateY(-2px);
}

.hero-stats {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 20px 32px;
  background: rgba(255,255,255,0.03);
  border: 1px solid rgba(255,183,3,0.2);
  border-radius: 80px;
  backdrop-filter: blur(12px);
  flex-wrap: wrap;
}

.hero-stat {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 32px;
}

.hero-stat-num {
  font-size: 2rem;
  font-weight: 800;
  background: linear-gradient(135deg, #FFB703, #FFD966);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}

.hero-stat-label {
  font-size: 0.8rem;
  color: #A0A0A0;
  margin-top: 5px;
}

.hero-stat-sep {
  width: 1px;
  height: 40px;
  background: rgba(255,183,3,0.2);
}

/* Sección Calidad */
.calidad-seccion {
  max-width: 1100px;
  margin: 80px auto;
  padding: 0 20px;
}

.calidad-titulo {
  text-align: center;
  font-size: 2rem;
  font-weight: 700;
  color: #FFFFFF;
  margin-bottom: 50px;
}

.calidad-grid {
  display: flex;
  justify-content: center;
  gap: 30px;
  flex-wrap: wrap;
}

.calidad-item {
  flex: 1;
  text-align: center;
  min-width: 120px;
}

.calidad-icono {
  width: 140px;
  height: 140px;
  margin: 0 auto 15px;
  border-radius: 50%;
  overflow: hidden;
  border: 2px solid rgba(255,183,3,0.3);
  transition: all 0.3s ease;
}

.calidad-icono:hover {
  transform: translateY(-8px);
  border-color: #FFB703;
  box-shadow: 0 10px 30px rgba(255,183,3,0.2);
}

.calidad-icono img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.calidad-item p {
  color: #CCCCCC;
  font-weight: 500;
  margin-top: 10px;
}

/* Sección Técnicas */
.tecnicas-seccion {
  width: 100%;
  padding: 60px 0;
  background: linear-gradient(135deg, #0F0F0F, #1A1A1A);
}

.tecnicas-titulo {
  text-align: center;
  font-size: 2rem;
  font-weight: 700;
  color: #FFFFFF;
  margin-bottom: 15px;
}

.tecnicas-subtitulo {
  text-align: center;
  color: #B0B0B0;
  margin-bottom: 50px;
}

.tecnica-card {
  flex: 1;
  min-width: 180px;
  max-width: 220px;
  border-radius: 24px;
  overflow: hidden;
  cursor: pointer;
  transition: all 0.3s ease;
  height: 260px;
  border: 1px solid rgba(255,183,3,0.2);
}

.tecnica-card:hover {
  transform: translateY(-8px);
  border-color: #FFB703;
  box-shadow: 0 10px 30px rgba(255,183,3,0.2);
}

.tecnica-card-overlay {
  background: linear-gradient(135deg, rgba(0,0,0,0.7), rgba(0,0,0,0.5));
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.tecnica-nombre {
  font-size: 1.1rem;
  font-weight: 700;
  color: #FFB703;
  text-align: center;
  padding: 20px;
}

/* Sección Tratamientos */
.tratamientos-seccion {
  width: 100%;
  background: linear-gradient(135deg, #0A0A0A, #151515);
  padding: 80px 0;
}

.tratamientos-titulo {
  text-align: center;
  font-size: 2.2rem;
  font-weight: 700;
  color: #FFFFFF;
  margin-bottom: 15px;
}

.tratamientos-subtitulo {
  text-align: center;
  color: #B0B0B0;
  margin-bottom: 50px;
}

.mosaico-destacado {
  border-radius: 32px;
  margin-bottom: 48px;
  cursor: pointer;
  border: 1px solid rgba(255,183,3,0.2);
  transition: all 0.3s ease;
}

.mosaico-destacado:hover {
  transform: translateY(-5px);
  border-color: #FFB703;
  box-shadow: 0 15px 35px rgba(255,183,3,0.15);
}

.mosaico-destacado-overlay {
  background: linear-gradient(135deg, rgba(0,0,0,0.75), rgba(0,0,0,0.6));
  padding: 70px 50px;
  text-align: center;
  border-radius: 32px;
}

.mosaico-badge {
  display: inline-block;
  background: #FFB703;
  padding: 6px 18px;
  border-radius: 40px;
  font-size: 0.75rem;
  font-weight: 700;
  color: #0A0A0A;
  margin-bottom: 20px;
}

.mosaico-destacado-contenido h3 {
  font-size: 2.2rem;
  font-weight: 700;
  color: #FFFFFF;
  margin-bottom: 15px;
}

.mosaico-destacado-contenido p {
  color: #CCCCCC;
  margin-bottom: 25px;
}

.mosaico-btn {
  display: inline-block;
  padding: 12px 32px;
  background: #FFB703;
  border-radius: 50px;
  color: #0A0A0A;
  font-weight: 700;
  transition: all 0.3s ease;
}

.mosaico-btn:hover {
  transform: translateX(5px);
  background: #FFD966;
}

.btn-ver-todo {
  display: block;
  margin: 40px auto 0;
  padding: 14px 40px;
  background: transparent;
  border: 2px solid #FFB703;
  border-radius: 50px;
  color: #FFB703;
  font-weight: 700;
  cursor: pointer;
  transition: all 0.3s ease;
}

.btn-ver-todo:hover {
  background: #FFB703;
  color: #0A0A0A;
}

@media (max-width: 768px) {
  .hero-stats { flex-direction: column; gap: 15px; border-radius: 40px; }
  .hero-stat-sep { display: none; }
  .hero-stat { padding: 5px 0; }
  .mosaico-destacado-contenido h3 { font-size: 1.5rem; }
}
/* Estilos para imágenes dentro de los orbes */
.hero-orb-1, .hero-orb-2, .hero-orb-3 {
  overflow: hidden;
}

.orb-carrusel {
  display: flex;
  flex-direction: column;
  transition: transform 0.8s ease-in-out;
  width: 100%;
  height: 100%;
}

.orb-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  flex-shrink: 0;
}
/* Brillo fulminante SOLO en los bordes de los orbes (sin movimiento) */
.hero-orb-1, .hero-orb-2, .hero-orb-3 {
  box-shadow: 0 0 40px rgba(255,183,3,0.5), 0 0 80px rgba(255,183,3,0.2);
  transition: box-shadow 0.3s ease;
}

.hero-orb-1:hover, .hero-orb-2:hover, .hero-orb-3:hover {
  box-shadow: 0 0 60px rgba(255,183,3,0.7), 0 0 100px rgba(255,183,3,0.4);
}

.hero-logo {
  filter: grayscale(1) brightness(1.2) contrast(1.1);
  transition: all 0.4s ease;
  cursor: pointer;
  animation: ecoPulse 3s ease-in-out infinite;
  transform-origin: center;
}

.hero-logo:hover {
  filter: grayscale(0) brightness(1) contrast(1);
  transform: scale(1.05);
  filter: drop-shadow(0 0 20px rgba(255,183,3,0.7));
  animation: none;
}

@keyframes ecoPulse {
  0% {
    filter: grayscale(1) brightness(1.2) contrast(1.1);
    transform: scale(1);
  }
  50% {
    filter: grayscale(0.3) brightness(1.15) contrast(1.05);
    transform: scale(1.02);
    filter: drop-shadow(0 0 8px rgba(255,183,3,0.3));
  }
  100% {
    filter: grayscale(1) brightness(1.2) contrast(1.1);
    transform: scale(1);
  }
}
/* Carrusel vertical (por defecto) */
.orb-carrusel {
  display: flex;
  flex-direction: column;
  transition: transform 0.8s ease-in-out;
  width: 100%;
  height: 100%;
}

/* Carrusel horizontal (para derecha/izquierda) */
.orb-carrusel.horizontal {
  flex-direction: row;
}
.tecnicas-grid {
  display: flex;
  flex-direction: row;
  justify-content: center;
  gap: 25px;
  flex-wrap: wrap;
  overflow-x: auto;
  padding-bottom: 20px;
}

.tecnica-card {
  flex: 0 0 auto;
  width: 220px;
  min-width: 180px;
  max-width: 220px;
  border-radius: 24px;
  overflow: hidden;
  cursor: pointer;
  transition: all 0.3s ease;
  height: 260px;
  border: 1px solid rgba(255,183,3,0.2);
}
/* Sección Técnicas */
