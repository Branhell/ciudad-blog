}
.tecnicas-seccion {
  width: 100%;
  padding: 60px 20px;
  background: linear-gradient(135deg, #2A2A2A 0%, #3A3A3A 100%);
}
/* ==============================================
   TÉCNICAS PSICOLÓGICAS - CON CUADRO FLOTANTE
   ============================================== */

.tecnicas-grid {
  display: flex;
  flex-direction: row;
  justify-content: center;
  gap: 25px;
  flex-wrap: wrap;
  max-width: 1200px;
  margin: 0 auto;
}

.tecnica-card {
  position: relative;
  flex: 0 0 auto;
  width: 220px;
  height: 260px;
  border-radius: 24px;
  overflow: visible;
  cursor: pointer;
  transition: all 0.3s ease;
  border: 1px solid rgba(255,183,3,0.3);
  box-shadow: 0 4px 15px rgba(0,0,0,0.3);
  background-size: cover;
  background-position: center;
}

.tecnica-card:hover {
  transform: translateY(-8px);
  border-color: #FFB703;
  box-shadow: 0 10px 30px rgba(255,183,3,0.2);
}

.tecnica-card-overlay {
  background: linear-gradient(135deg, rgba(0,0,0,0.7), rgba(0,0,0,0.5));
  width: 100%;
  height: 100%;
  border-radius: 24px;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.tecnica-nombre {
  font-size: 1.1rem;
  font-weight: 700;
  color: #FFB703;
  text-align: center;
  padding: 20px;
  margin: 0;
}

/* Cuadro flotante (tooltip) */
.tecnica-hover-info {
  position: absolute;
  bottom: 100%;
  left: 50%;
  transform: translateX(-50%);
  background: #1A1A1A;
  color: #E0E0E0;
  border-radius: 12px;
  padding: 12px;
  width: 220px;
  font-size: 0.75rem;
  line-height: 1.5;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
  pointer-events: none;
  z-index: 1000;
  border: 1px solid #FFB703;
  box-shadow: 0 4px 15px rgba(0,0,0,0.3);
  margin-bottom: 8px;
}
.tecnica-card {
  position: relative !important;
}

.tecnicas-grid {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 20px;
  justify-content: center;
}

.tecnica-card {
  position: relative;
  width: 220px;
  height: 260px;
  border-radius: 20px;
  overflow: hidden;
  cursor: pointer;
  transition: transform 0.3s;
}

.tecnica-card:hover {
  transform: translateY(-5px);
}

.tecnica-card-overlay {
  width: 100%;
  height: 100%;
  background: rgba(0,0,0,0.6);
  display: flex;
  align-items: center;
  justify-content: center;
}

.tecnica-nombre {
  color: #FFB703;
  text-align: center;
  font-weight: bold;
  padding: 10px;
}

.tecnica-hover-info {
  position: absolute;
  bottom: 100%;
  left: 50%;
  transform: translateX(-50%);
  background: black;
  color: white;
  padding: 10px;
  border-radius: 10px;
  width: 200px;
  font-size: 12px;
  opacity: 0;
  visibility: hidden;
  transition: 0.3s;
  border: 1px solid #FFB703;
  z-index: 1000;
}
/* ==============================================
   CUADRO FLOTANTE PARA TÉCNICAS
   ============================================== */

.tecnica-card {
  position: relative !important;
}

.tecnica-hover-info {
  position: absolute !important;
  bottom: 100% !important;
  left: 50% !important;
  transform: translateX(-50%) !important;
  background: #1A1A1A !important;
  color: #E0E0E0 !important;
  border-radius: 12px !important;
  padding: 12px !important;
  width: 220px !important;
  font-size: 0.75rem !important;
  line-height: 1.5 !important;
  opacity: 0 !important;
  visibility: hidden !important;
  transition: all 0.3s ease !important;
  pointer-events: none !important;
  z-index: 9999 !important;
  border: 1px solid #FFB703 !important;
  box-shadow: 0 4px 15px rgba(0,0,0,0.3) !important;
  margin-bottom: 8px !important;
}

.tecnica-card:hover .tecnica-hover-info {
  opacity: 1 !important;
  visibility: visible !important;
  transform: translateX(-50%) translateY(-5px) !important;
}