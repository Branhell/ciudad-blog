}

.tecnicas-subtitulo {
  text-align: center;
  font-size: 1rem;
  color: #CCCCCC;
  margin-bottom: 40px;
  max-width: 700px;
  margin-left: auto;
  margin-right: auto;
}

.tecnicas-grid {
